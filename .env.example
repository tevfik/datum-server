# Server Configuration
PORT=8000
SERVER_URL=http://localhost:8000
DATA_DIR=./data

# Database (Leave empty for BuntDB/TStorage, set for Postgres)
DATABASE_URL=postgres://user:password@localhost:5432/datum?sslmode=disable

# Authentication Provider: 'local' (default) or 'supabase'
AUTH_PROVIDER=local

# Supabase Configuration (Required if AUTH_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Performance Tuning
GOGC=100

# Security (For Local Provider)
JWT_SECRET=change_me_to_a_secure_random_string
