# Server Configuration
PORT=8000
LOG_LEVEL=INFO
GIN_MODE=release

# Security
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars

# Data Retention
RETENTION_MAX_DAYS=7

# Traefik / SSL Configuration
# NOTE: These are only required if you are using the bundled Traefik service (Option 1).
# If you are using an existing external Traefik proxy, these are not used.

# Required for automatic HTTPS with bundled Traefik
ACME_EMAIL=admin@example.com
DOMAIN=localhost

# Traefik Entrypoints
# If using an existing Traefik, match these to your existing entrypoint names (e.g., http, https)
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_ENTRYPOINT_HTTPS=websecure

# External Traefik Configuration (for docker-compose.external.yml)
# The Docker network name where your existing Traefik is running
TRAEFIK_NETWORK=proxy
# The cert resolver name defined in your existing Traefik
TRAEFIK_CERTRESOLVER=letsencrypt

# Let's Encrypt SSL certificates directory (host directory)
# Ensures certificates are persisted across container restarts to avoid rate limits.
# Only used by the bundled Traefik service.
# Use absolute path for production: /var/lib/datum/letsencrypt
LETSENCRYPT_DIR=./letsencrypt
