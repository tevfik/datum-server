# Server Configuration
# DOMAIN: Used by Docker/Traefik for host routing (e.g., example.com or datum.localhost)
DOMAIN=datum.localhost

# SERVER_URL: Public access URL (used by clients)
# If using Docker with DOMAIN, this should be https://${DOMAIN}
SERVER_URL=https://datum.localhost
PORT=8000

# App Data
DATA_DIR=./data
RETENTION_MAX_DAYS=7
CORS_ORIGINS=*

# Security
# Generate a secure secret using `openssl rand -hex 32`
JWT_SECRET=change_me_to_a_secure_secret
# ACME Email (for Let's Encrypt in Docker)
ACME_EMAIL=admin@example.com

# Email Configuration (Resend API)
RESEND_API_KEY=re_123456789
EMAIL_FROM=onboarding@resend.dev

# Logging
LOG_LEVEL=INFO

# Database Configuration (PostgreSQL)
# If POSTGRES variables are set, DATABASE_URL is constructed automatically in Docker.
# Or set DATABASE_URL directly: postgres://user:pass@host:5432/dbname?sslmode=disable
# POSTGRES_USER=datum
# POSTGRES_PASSWORD=datum_secret
# POSTGRES_DB=datum

