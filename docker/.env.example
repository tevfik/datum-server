# Datum IoT Platform - Server Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# Server Configuration
# ============================================

# Server port (can also use --port flag)
PORT=8000

# Public Server URL (used for device provisioning)
# Required if running behind a proxy or load balancer
# Example: https://datum.example.com
# Default: http://localhost:8000
SERVER_URL=https://datum.example.com

# Data directory for storage (host directory, relative to docker-compose.yml)
# This directory will be created automatically and mounted to container
# Use absolute path for production: /var/lib/datum/data
DATA_DIR=../data

# Let's Encrypt SSL certificates directory (host directory)
# Use absolute path for production: /var/lib/datum/letsencrypt
LETSENCRYPT_DIR=./letsencrypt

# ============================================
# Domain & SSL Configuration
# ============================================

# Primary domain for Traefik routing
DOMAIN=datum.example.com

# Email for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# Traefik Entrypoints
# If using an existing Traefik, match these to your existing entrypoint names.
# Example: If your Traefik has --entrypoints.web80.address=:80, use 'web80' here.
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_ENTRYPOINT_HTTPS=websecure

# External Traefik Configuration (for docker-compose.external.yml)
# The Docker network name where your existing Traefik is running
TRAEFIK_NETWORK=proxy
# The cert resolver name defined in your existing Traefik
# myresolver
TRAEFIK_CERTRESOLVER=letsencrypt

# ============================================
# Security Configuration
# ============================================

# JWT secret for token signing (minimum 32 characters recommended)
# CRITICAL: Generate a secure random string in production!
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# CORS allowed origins (comma-separated, use * for all origins)
# Examples: https://app.example.com,https://dashboard.example.com
# Default: * (all origins - only use in development)
CORS_ORIGINS=*

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARN, ERROR, FATAL (default: INFO)
LOG_LEVEL=INFO

# Log format: pretty (human-readable, colored) or json (production)
# Default: pretty
LOG_FORMAT=pretty

# Traefik log level: DEBUG, INFO, WARN, ERROR
TRAEFIK_LOG_LEVEL=INFO

# ============================================
# Data Retention Configuration
# ============================================

# Maximum age of data in days (can also use --retention-days flag)
RETENTION_MAX_DAYS=7

# Cleanup check interval in hours (can also use --retention-check-hours flag)
RETENTION_CHECK_HOURS=24

# ============================================
# Rate Limiting Configuration
# ============================================

# Maximum requests per window
RATE_LIMIT_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# Storage Paths (Optional)
# ============================================

# Time-series data path (optional override)
# TSDATA_PATH=/custom/path/tsdata

# ============================================
# Production Deployment Notes
# ============================================

# 1. Generate secure JWT_SECRET:
#    openssl rand -base64 32
#
# 2. Set your domain:
#    DOMAIN=iot.yourcompany.com
#
# 3. Set your email for SSL:
#    ACME_EMAIL=ssl-admin@yourcompany.com
#
# 4. Restrict CORS in production:
#    CORS_ORIGINS=https://dashboard.yourcompany.com
#
# 5. Adjust rate limiting for production:
#    RATE_LIMIT_REQUESTS=1000
#    RATE_LIMIT_WINDOW_SECONDS=60
#
# 6. Enable JSON logging for production:
#    LOG_FORMAT=json
#    LOG_LEVEL=WARN
#
# 7. Traefik will automatically provision SSL certificates via Let's Encrypt
#    Make sure ports 80 and 443 are accessible from the internet
#
# Command-line flags take precedence over environment variables:
#   ./datum-server --port 9000 --data-dir /var/lib/datum
#
# Priority: Command-line flags > Environment variables > Defaults
#
# See README.md for complete configuration options
