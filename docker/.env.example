# =============================================================================
# DATUM SERVER CONFIGURATION
# =============================================================================

# --- Server Settings ---
# Port for the HTTP API server
PORT=8000
# Public URL where the server is accessible (used for links in emails, etc.)
SERVER_URL=https://localhost
# CORS allowed origins (comma separated or * for all)
# Used by server for Access-Control-Allow-Origin and WebSocket origin validation
CORS_ALLOWED_ORIGINS=*
# Enable HSTS header (Strict-Transport-Security) - set to "true" in production with HTTPS
ENABLE_HSTS=false
# Skip serving the web UI (if frontend is deployed separately)
SKIP_WEB=0

# --- Database Configuration ---
# PostgreSQL connection string
DATABASE_URL=postgres://datum:datum_secret@postgres:5432/datum?sslmode=disable
# Postgres variables (often used by docker-compose)
POSTGRES_USER=datum
POSTGRES_PASSWORD=datum_secret
POSTGRES_DB=datum

# --- Security & Authentication ---
# JWT Secret Key (CRITICAL: Change this to a random 32+ char string in production)
JWT_SECRET=change_me_to_a_secure_random_string_min_32_chars
# Refresh token expiration in days (default: 30)
JWT_REFRESH_EXPIRY=30
# Access token expiration in minutes (default: 15). 
# Increase this (e.g., 1440 for 24h) to keep multiple devices logged in longer (Access tokens are not checked against DB).
JWT_ACCESS_EXPIRY_MINUTES=15
# Basic Auth for API Documentation (Swagger UI)
DOCS_USER=admin
DOCS_PASS=secure_password

# --- Rate Limiting ---
# Max requests per window
RATE_LIMIT_REQUESTS=1000
# Window size in seconds (e.g. 60 seconds)
RATE_LIMIT_WINDOW_SECONDS=60

# --- Request Limits ---
# Maximum request body size in bytes (default: 5MB)
MAX_REQUEST_BODY_BYTES=5242880
# Maximum number of data points returned in a single query (default: 10000)
QUERY_MAX_LIMIT=10000
# Telemetry buffer size for burst absorption (default: 10000, increase for high-throughput deployments)
# TELEMETRY_BUFFER_SIZE=10000

# --- Content Security Policy ---
# Override the default CSP header (optional)
# CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data:; connect-src 'self' ws: wss:;

# --- MQTT Broker Integration ---
# These ports are typically mapped by Docker/Traefik
MQTT_TCP_PORT=1883
MQTT_WS_PORT=1884
# MQTT TLS (optional): set cert and key paths to enable TLS on port 8883
# MQTT_TLS_CERT=/path/to/cert.pem
# MQTT_TLS_KEY=/path/to/key.pem

# --- Logging ---
# Log Level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
# Log Format: json, console (pretty) - corresponds to LOG_OUTPUT in codebase
# LOG_FORMAT is present in docker-compose but ignored by server code in favor of LOG_OUTPUT
LOG_OUTPUT=json
# LOG_FORMAT=pretty
TRAEFIK_LOG_LEVEL=INFO

# --- Email Service (Resend) ---
# API Key for Resend.com
RESEND_API_KEY=re_12345678
# Sender email address
EMAIL_FROM=noreply@example.com

# --- Data Retention ---
# Maximum days to keep telemetry data (0 = infinite) -> Global Physical Retention
RETENTION_MAX_DAYS=7
# Days to keep Public API data (Soft Limit) - Default: 1
PUBLIC_DATA_RETENTION_DAYS=1
# Interval in hours to check for old data (deprecated in newer versions, handled by DB)
RETENTION_CHECK_HOURS=24

# =============================================================================
# INFRASTRUCTURE / DOCKER CONFIGURATION
# =============================================================================

# --- General ---
# Data directory path
DATA_DIR=../data
# Path for time-series data storage (defaults to DATA_DIR/tsdata if not set)
TSDATA_PATH=
DOMAIN=localhost

# --- SSL / Let's Encrypt ---
LETSENCRYPT_DIR=./letsencrypt
ACME_EMAIL=admin@example.com

# --- Traefik Proxy Settings ---
TRAEFIK_ENTRYPOINT_HTTP=web80
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_NETWORK=int_docker
TRAEFIK_CERTRESOLVER=myresolver
