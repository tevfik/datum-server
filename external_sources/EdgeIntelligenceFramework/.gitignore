# =============================================================================
# EIF .gitignore
# =============================================================================

# =============================================================================
# Build Artifacts
# =============================================================================
build/
!tools/build/
bin/
lib/
*.o
*.a
*.so
*.dylib
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

compile_commands.json

# =============================================================================
# Python Virtual Environment
# =============================================================================
.venv/
venv/
env/
.env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
*.egg

# =============================================================================
# External Libraries (for comparison only)
# =============================================================================
compare_lib/

# =============================================================================
# Demo/Test Output Files
# =============================================================================
output/
*.pgm
*.ppm
*.png
*.jpg
*.jpeg
*.bmp
*.wav
*.raw
eq_output.json

# =============================================================================
# IDE and Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.code-workspace

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.log
*.bak
*.orig

# =============================================================================
# Model Files (optional - uncomment if needed)
# =============================================================================
# models/*.bin
# models/*.tflite
# models/*.onnx

# =============================================================================
# Documentation Build
# =============================================================================
docs/_build/
docs/html/
docs/api/
site/

# =============================================================================
# Coverage and Testing
# =============================================================================
coverage/
*.gcov
*.gcda
*.gcno
.coverage
htmlcov/
tools/analysis/reports/
